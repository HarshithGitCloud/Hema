{
	"name": "ConverstingJsonToParquet",
	"properties": {
		"nbformat": 4,
		"nbformat_minor": 2,
		"bigDataPool": {
			"referenceName": "sparkpool",
			"type": "BigDataPoolReference"
		},
		"sessionProperties": {
			"driverMemory": "28g",
			"driverCores": 4,
			"executorMemory": "28g",
			"executorCores": 4,
			"numExecutors": 2,
			"conf": {
				"spark.dynamicAllocation.enabled": "false",
				"spark.dynamicAllocation.minExecutors": "2",
				"spark.dynamicAllocation.maxExecutors": "2",
				"spark.autotune.trackingId": "9f9f0ac4-718b-464d-9a53-50d805abc6af"
			}
		},
		"metadata": {
			"saveOutput": true,
			"enableDebugMode": false,
			"kernelspec": {
				"name": "synapse_pyspark",
				"display_name": "Synapse PySpark"
			},
			"language_info": {
				"name": "python"
			},
			"a365ComputeOptions": {
				"id": "/subscriptions/16a3eefe-7a80-4357-b186-6221ffab82f1/resourceGroups/reg_datamart/providers/Microsoft.Synapse/workspaces/synapseanalyticsdevenv/bigDataPools/sparkpool",
				"name": "sparkpool",
				"type": "Spark",
				"endpoint": "https://synapseanalyticsdevenv.dev.azuresynapse.net/livyApi/versions/2019-11-01-preview/sparkPools/sparkpool",
				"auth": {
					"type": "AAD",
					"authResource": "https://dev.azuresynapse.net"
				},
				"sparkVersion": "3.4",
				"nodeCount": 10,
				"cores": 4,
				"memory": 28,
				"automaticScaleJobs": false
			},
			"sessionKeepAliveTimeout": 30
		},
		"cells": [
			{
				"cell_type": "code",
				"source": [
					"storage_account = \"sadevenvdatamart\"  \n",
					"container = \"adlsgen2\"\n",
					"\n",
					"source_folder = \"/staging/OnPremSQLServer/tempjson/\"\n",
					"target_folder = \"/staging/OnPremSQLServer/parquet/\"\n",
					"\n",
					"files = [\"flights_raw\",\"bookings_raw\"]\n",
					"\n",
					"for file in files:\n",
					"\n",
					"    json_path = f\"abfss://{container}@{storage_account}.dfs.core.windows.net/{source_folder}{file}.json\"\n",
					"    parquet_path = f\"abfss://{container}@{storage_account}.dfs.core.windows.net/{target_folder}{file}\"\n",
					"\n",
					"    df = spark.read.option(\"multiline\",\"false\").json(json_path)\n",
					"\n",
					"    df.write.mode(\"overwrite\").parquet(parquet_path)\n",
					"\n",
					"    print(f\"{file} converted to parquet successfully\")"
				],
				"execution_count": 5
			}
		]
	}
}