		"cells": [
			{
				"cell_type": "code",
				"source": [
					"files = [\"flights_raw\",\"bookings_raw\",\"airports_raw\"]\n",
					"\n",
					"for file in files:\n",
					"    \n",
					"    json_path = f\"abfss://container@storageaccount.dfs.core.windows.net/staging/OnPremSQLServer/tempjson/{file}.json\"\n",
					"    parquet_path = f\"abfss://container@storageaccount.dfs.core.windows.net/staging/OnPremSQLServer/parquet/{file}\"\n",
					"    \n",
					"    df = spark.read.json(json_path)\n",
					"    \n",
					"    df.write.mode(\"overwrite\").parquet(parquet_path)\n",
					"    \n",
					"    print(f\"{file} converted to parquet\")"
				],
				"execution_count": 2
			}
		]
	}
}