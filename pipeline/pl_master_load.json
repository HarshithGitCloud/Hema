{
	"name": "pl_master_load",
	"properties": {
		"activities": [
			{
				"name": "raw_Layer",
				"type": "ExecutePipeline",
				"dependsOn": [],
				"policy": {
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"waitOnCompletion": true
				}
			},
			{
				"name": "GetPreintigration",
				"type": "Lookup",
				"dependsOn": [
					{
						"activity": "raw_Layer",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": "SELECT  * FROM [dbo].[notebookExecutionConfig] where flag = 1 and source = 'OnPremSQLServer' and layer = 'P'",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "AzureSqlTable1",
						"type": "DatasetReference",
						"parameters": {
							"SchemaName": "dbo",
							"TableName": "notebookExecutionConfig"
						}
					},
					"firstRowOnly": false
				}
			},
			{
				"name": "ForEach1",
				"type": "ForEach",
				"dependsOn": [
					{
						"activity": "GetPreintigration",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@activity('GetPreintigration').output.value",
						"type": "Expression"
					},
					"activities": [
						{
							"name": "Pre Intigration Notebook",
							"type": "SynapseNotebook",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"notebook": {
									"referenceName": {
										"value": "@trim(item().notebook_name)",
										"type": "Expression"
									},
									"type": "NotebookReference"
								},
								"snapshot": true,
								"sparkPool": {
									"referenceName": "sparkpool",
									"type": "BigDataPoolReference"
								},
								"executorSize": "Small",
								"conf": {
									"spark.dynamicAllocation.enabled": true
								},
								"driverSize": "Small"
							}
						},
						{
							"name": "PreIntigration_Parellel_Error",
							"type": "SetVariable",
							"dependsOn": [
								{
									"activity": "Pre Intigration Notebook",
									"dependencyConditions": [
										"Failed"
									]
								}
							],
							"policy": {
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"variableName": "Var_PreIntigration",
								"value": {
									"value": "@concat('item: ',string(item()), '-Error: ',activity('GetPreintigration').error.message)",
									"type": "Expression"
								}
							}
						},
						{
							"name": "Fail_PreIntigration",
							"type": "Fail",
							"dependsOn": [
								{
									"activity": "PreIntigration_Parellel_Error",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"userProperties": [],
							"typeProperties": {
								"message": "PipeLineFailed-PreIntigration",
								"errorCode": "400"
							}
						}
					]
				}
			},
			{
				"name": "Get List Of Stage Tables",
				"type": "Lookup",
				"dependsOn": [
					{
						"activity": "ForEach1",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": []
			}
		],
		"variables": {
			"Var_PreIntigration": {
				"type": "String"
			}
		},
		"annotations": []
	}
}