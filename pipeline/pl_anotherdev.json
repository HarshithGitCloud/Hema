											"value": "@data().SourceDBUserName",
											"type": "Expression"
										}
									}
								}
							],
							"outputs": [
								{
									"referenceName": "Json1",
									"type": "DatasetReference",
									"parameters": {
										"Directory": "@concat('staging/',item().SourceName,'/tempjson/')",
										"FileName": "@concat('staging/',item().SourceName,'/tempjson/')"
									}
								}
							]
						}
					]
				}
			},
